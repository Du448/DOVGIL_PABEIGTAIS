# Google Places API key for the reviews endpoint
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Google Places place ID for the reviews endpoint
GOOGLE_PLACE_ID=your_google_place_id

# Public site URL used for canonical metadata and sitemap URLs
NEXT_PUBLIC_SITE_URL=https://example.com

# Resend API key for inquiry email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Destination email address for inquiry submissions
INQUIRY_TO_EMAIL=inquiries@example.com

# Toggle for showing Inbank financing UI features
NEXT_PUBLIC_FEATURE_INBANK=false

# Inbank calculator base URL. Use https://demo-calculator.inbank.ee/calculator/indivy/plan for staging
# and https://calculator.inbank.ee/calculator/indivy/plan for production. The embedding domain must be
# whitelisted by Inbank for the iframe to load correctly.
NEXT_PUBLIC_INBANK_CALCULATOR_URL=https://demo-calculator.inbank.ee/calculator/indivy/plan

# Inbank shop UUID used for financing integration
NEXT_PUBLIC_INBANK_SHOP_UUID=your_inbank_shop_uuid

# Inbank product code used for financing integration
NEXT_PUBLIC_INBANK_PRODUCT_CODE=your_inbank_product_code

# Optional public domain for Plausible analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com

# Optional Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
