# Google Places API key for the reviews endpoint
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Google Places place ID for the reviews endpoint
GOOGLE_PLACE_ID=your_google_place_id

# Public site URL used for canonical metadata and sitemap URLs
NEXT_PUBLIC_SITE_URL=https://example.com

# Resend API key for inquiry email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Destination email address for inquiry submissions
INQUIRY_TO_EMAIL=inquiries@example.com

# Inbank calculator feature flag. "true" shows the calculator.
NEXT_PUBLIC_FEATURE_INBANK=false

# Inbank Partner Portal shop UUID.
NEXT_PUBLIC_INBANK_SHOP_UUID=

# Inbank Partner Portal product code.
NEXT_PUBLIC_INBANK_PRODUCT_CODE=

# Inbank region used by the calculator widget. "lv" = production, "lvdemo" = demo/test environment.
NEXT_PUBLIC_INBANK_REGION=lv

# Inbank calculator script URL. Demo example: https://demo-calculator.inbank.eu/api/calculator
NEXT_PUBLIC_INBANK_SCRIPT_URL=https://calculator.inbank.eu/api/calculator

# NOTE: the Inbank Shop API key is NOT used by the calculator and must never be exposed client-side
# (no NEXT_PUBLIC prefix, do not add it here).

# Optional public domain for Plausible analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com

# Optional Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
